NODE_ENV=development

# Shared service URLs
PORT=3000
CLIENT_ORIGIN=*
BACKEND_API_BASE_PATH=/api/v1
AI_SERVICE_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:3000/api/v1

# Database
DB_HOST=localhost
DB_PORT=1433
DB_NAME=AI_LearningCareerDB
DB_USER=sa
DB_PASSWORD=your_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Authentication
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# Uploads
UPLOAD_MAX_FILE_SIZE=5242880

# AI provider
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
AI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
