NODE_ENV=development

# Shared service URLs
PORT=3000
CLIENT_ORIGIN=*
BACKEND_API_BASE_PATH=/api/v1
AI_SERVICE_URL=http://localhost:8000
BACKEND_API_URL=http://localhost:3000/api/v1

# Database
# Copy this file to .env before starting the backend or AI service.
# The backend reads DB_HOST, DB_PORT, DB_NAME, DB_USER and DB_PASSWORD from .env.
# Use a real SQL Server login and password that can access AI_LearningCareerDB.
DB_HOST=localhost
DB_PORT=1433
DB_NAME=AI_LearningCareerDB
DB_USER=sa
DB_PASSWORD=your_sql_server_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Docker database connection overrides
# Use these when running docker compose so containers do not point to localhost.
DOCKER_DB_HOST=host.docker.internal
DOCKER_DB_PORT=1433
DOCKER_DB_NAME=AI_LearningCareerDB
DOCKER_DB_USER=sa
DOCKER_DB_PASSWORD=your_sql_server_password
DOCKER_DB_ENCRYPT=false
DOCKER_DB_TRUST_SERVER_CERTIFICATE=true

# Authentication
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# Uploads
UPLOAD_MAX_FILE_SIZE=5242880

# AI provider
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
AI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
